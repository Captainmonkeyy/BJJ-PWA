.back {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #57534E;
  margin-bottom: 28rpx;
  font-size: 28rpx;
}

.back .icon {
  color: #57534E;
}

.header-card {
  margin-bottom: 40rpx;
}

.header-row {
  margin-bottom: 12rpx;
}

.tech-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1917;
}

.tech-tags {
  font-size: 28rpx;
  color: #57534E;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #1C1917;
}

.notes-content {
  font-size: 28rpx;
  color: #1C1917;
  line-height: 1.6;
  white-space: pre-wrap;
}

.loading {
  text-align: center;
  padding: 72rpx;
  color: #A8A29E;
}

.btn-edit {
  font-size: 28rpx;
  color: #292524;
  font-weight: 500;
}
