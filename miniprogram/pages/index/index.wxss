.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1C1917;
}

.btn-with-icon {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-with-icon .icon {
  color: #FFFFFF;
}

.empty {
  text-align: center;
  padding: 72rpx 28rpx;
  color: #A8A29E;
  font-size: 28rpx;
}

.link {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 28rpx;
  color: #292524;
  font-weight: 500;
}

.empty .link {
  padding: 20rpx 28rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
}

.link .icon {
  color: #292524;
}

.item {
  margin-bottom: 28rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-name {
  font-weight: 500;
  color: #1C1917;
  font-size: 32rpx;
}

.item-sub {
  display: block;
  font-size: 24rpx;
  color: #57534E;
  margin-top: 12rpx;
}

.section-block {
  margin-bottom: 40rpx;
}

.empty-small {
  font-size: 24rpx;
  color: #A8A29E;
  padding: 24rpx 0;
}

.brand {
  font-size: 36rpx;
  font-weight: 600;
  color: #1C1917;
}

.arrow {
  color: #A8A29E;
}

.tags {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  background: #FAFAF9;
  border: 1rpx solid #E7E5E4;
  border-radius: 8rpx;
  color: #57534E;
}

.more {
  font-size: 24rpx;
  color: #A8A29E;
}
