.back {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #57534E;
  margin-bottom: 28rpx;
  font-size: 28rpx;
}

.section {
  margin-bottom: 28rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #57534E;
  margin-bottom: 12rpx;
}

.input {
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.btn-tag {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.btn-tag-active {
  background: #292524;
  color: #fff;
}

.btn-tag-outline {
  background: #F5F5F4;
  color: #57534E;
  border: 1rpx solid #E7E5E4;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-weight: 500;
  color: #1C1917;
}

.link {
  color: #292524;
  font-weight: 500;
}

.link-with-icon {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.canvas-area {
  min-height: 200rpx;
  background: #FAFAF9;
  border: 1rpx dashed #E7E5E4;
  border-radius: 12rpx;
  padding: 24rpx;
}

.canvas-empty {
  text-align: center;
  padding: 48rpx 24rpx;
  color: #A8A29E;
  font-size: 28rpx;
}

.hint {
  display: block;
  font-size: 24rpx;
  margin-top: 16rpx;
}

.tree-view {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tree-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.branch-label {
  font-size: 24rpx;
  color: #78716C;
  padding-left: 8rpx;
  margin-bottom: 8rpx;
}

.tree-connector {
  font-family: monospace;
  margin-right: 4rpx;
  color: #A8A29E;
}

.node-card {
  background: #fff;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.node-card.selected {
  border-color: #292524;
  background: #F5F5F4;
}

.node-content {
  flex: 1;
}

.node-type {
  font-size: 22rpx;
  color: #A8A29E;
  margin-right: 12rpx;
}

.node-label {
  font-weight: 500;
  color: #1C1917;
}

.node-actions {
  display: flex;
  gap: 24rpx;
}

.add-branch {
  font-size: 24rpx;
  color: #292524;
}

.remove-node {
  font-size: 24rpx;
  color: #A8A29E;
}

.add-branch.disabled {
  color: #A8A29E;
  font-size: 22rpx;
}

.note-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.note-input {
  flex: 1;
}

.remove {
  font-size: 24rpx;
  color: #57534E;
}

.submit {
  margin-top: 40rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
}

.modal-form {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-actions-col {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.modal-actions-col .btn-primary,
.modal-actions-col .btn-outline {
  width: 100%;
  text-align: center;
}

.btn-outline {
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  text-align: center;
  color: #1C1917;
}

.tech-list {
  max-height: 400rpx;
}

.tech-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #E7E5E4;
  font-size: 28rpx;
}

.empty-tip {
  padding: 32rpx;
  text-align: center;
  color: #A8A29E;
}
