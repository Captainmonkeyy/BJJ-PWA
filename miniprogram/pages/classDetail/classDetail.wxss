.back {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #57534E;
  margin-bottom: 28rpx;
  font-size: 28rpx;
}

.back .icon {
  color: #57534E;
}

.header-card {
  margin-bottom: 40rpx;
}

.header-row {
  margin-bottom: 12rpx;
}

.flow-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1917;
}

.flow-start {
  font-size: 28rpx;
  color: #57534E;
}

.btn-edit {
  font-size: 28rpx;
  color: #292524;
  font-weight: 500;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #1C1917;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.step-order {
  font-weight: 500;
  color: #57534E;
  flex-shrink: 0;
}

.step-text {
  color: #1C1917;
}

.decision-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.decision-item {
  font-size: 28rpx;
  color: #1C1917;
}

.note-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.note-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.note-bullet {
  color: #57534E;
  flex-shrink: 0;
}

.note-content {
  color: #1C1917;
}

.empty-detail {
  text-align: center;
  padding: 48rpx;
  color: #A8A29E;
  font-size: 28rpx;
}

.tree-view {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tree-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.branch-label {
  font-size: 24rpx;
  color: #78716C;
  padding-left: 8rpx;
  margin-bottom: 8rpx;
}

.tree-connector {
  font-family: monospace;
  margin-right: 4rpx;
  color: #A8A29E;
}

.node-card {
  background: #F5F5F4;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  padding: 20rpx;
}

.node-type {
  font-size: 22rpx;
  color: #A8A29E;
  margin-right: 12rpx;
}

.node-label {
  font-weight: 500;
  color: #1C1917;
}

.loading {
  text-align: center;
  padding: 72rpx;
  color: #A8A29E;
}
