.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  color: #1C1917;
}

.filter-group {
  margin-bottom: 28rpx;
}

.quick-filter {
  margin-bottom: 32rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E7E5E4;
}

.quick-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1917;
  margin-bottom: 8rpx;
}

.quick-hint {
  display: block;
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 16rpx;
}

.advanced-filter {
  margin-bottom: 28rpx;
}

.tags-row {
  margin-top: 12rpx;
}

.group {
  margin-bottom: 32rpx;
}

.group-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #57534E;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #57534E;
  margin-bottom: 20rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.count {
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 20rpx;
}

.tech-item {
  margin-bottom: 28rpx;
}

.tech-date {
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 12rpx;
}

.tech-header {
  margin-bottom: 12rpx;
}

.tech-name {
  font-weight: 500;
}

.tech-tags {
  display: block;
  font-size: 24rpx;
  color: #57534E;
  margin-top: 12rpx;
}

.tech-notes {
  font-size: 28rpx;
  color: #A8A29E;
  margin-top: 20rpx;
}

.empty {
  text-align: center;
  padding: 72rpx;
  color: #A8A29E;
}
