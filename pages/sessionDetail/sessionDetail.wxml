<view class="container" wx:if="{{session}}">
  <view class="back" bindtap="onBack">
    <view class="icon icon-chevron-left"></view>
    <text>返回</text>
  </view>

  <view class="card header-card">
    <view class="header-row flex-between">
      <view class="session-title">实战表现</view>
      <view class="btn-edit" bindtap="onEdit">编辑</view>
    </view>
    <text class="session-date">{{dateLine}}</text>
  </view>

  <view wx:if="{{classStateLabel}}" class="section">
    <view class="section-title-row">
      <view class="section-title">上课状态</view>
    </view>
    <view class="text-box">
      <text class="body-content" selectable="true">{{classStateLabel}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title-row">
      <view class="section-title">疼痛描述</view>
    </view>
    <view wx:if="{{painText}}" class="text-box">
      <text class="body-content" selectable="true">{{painText}}</text>
    </view>
    <view wx:if="{{!painText}}" class="muted">未填写</view>
  </view>

  <view class="section">
    <view class="section-title-row">
      <view class="section-title">实战表现</view>
    </view>
    <view wx:if="{{session.practiceNotes}}" class="text-box">
      <text class="body-content" selectable="true">{{session.practiceNotes}}</text>
    </view>
    <view wx:if="{{!session.practiceNotes}}" class="muted">未填写</view>
  </view>
</view>

<view wx:else class="loading">加载中...</view>
