.back {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #57534E;
  margin-bottom: 28rpx;
  font-size: 28rpx;
}

.back .icon {
  color: #57534E;
}

.header-card {
  margin-bottom: 40rpx;
}

.header-row {
  margin-bottom: 12rpx;
}

.tech-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1C1917;
}

.tech-tags {
  font-size: 28rpx;
  color: #57534E;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-weight: 500;
  color: #1C1917;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.copy-btn {
  font-size: 24rpx;
  color: #78716C;
}

.text-box {
  width: 100%;
  box-sizing: border-box;
}

.notes-content {
  font-size: 28rpx;
  color: #1c1917;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.loading {
  text-align: center;
  padding: 72rpx;
  color: #A8A29E;
}

.btn-edit {
  font-size: 28rpx;
  color: #292524;
  font-weight: 500;
}

.teach-video-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #FAFAF9;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.teach-video-row:last-child {
  margin-bottom: 0;
}

.teach-video-icon {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #292524;
}

.teach-video-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.teach-video-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #1C1917;
}

.teach-video-url {
  font-size: 22rpx;
  color: #78716C;
  word-break: break-all;
}

.teach-video-chevron {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #A8A29E;
  line-height: 1;
}
