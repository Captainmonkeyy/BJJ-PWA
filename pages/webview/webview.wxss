.empty {
  padding: 72rpx;
  text-align: center;
  color: #A8A29E;
  font-size: 28rpx;
}

.error-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: #FAFAF9;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  max-width: 600rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1C1917;
  text-align: center;
}

.error-desc {
  font-size: 26rpx;
  color: #78716C;
  text-align: center;
  line-height: 1.6;
}

.error-btn {
  margin-top: 16rpx;
  padding: 24rpx 64rpx;
  background: #1C1917;
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.error-btn-cancel {
  padding: 16rpx 32rpx;
  color: #A8A29E;
  font-size: 26rpx;
}