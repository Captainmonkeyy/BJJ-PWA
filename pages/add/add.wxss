.mode-tabs {
  display: flex;
  margin-bottom: 32rpx;
  background: #F5F5F4;
  border-radius: 12rpx;
  padding: 4rpx;
}

.mode-tabs-three .mode-tab {
  padding: 14rpx 8rpx;
  font-size: 26rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #57534E;
  border-radius: 8rpx;
}

.mode-tab.active {
  background: #FFFFFF;
  color: #1C1917;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
  color: #1C1917;
}

.record-date-section {
  margin-bottom: 28rpx;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: #A8A29E;
  margin-bottom: 12rpx;
}

.picker-row {
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1C1917;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #1C1917;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.link-with-icon {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  min-height: 64rpx;
}

.link-with-icon .icon {
  color: #292524;
}

.row {
  display: flex;
  gap: 20rpx;
  align-items: center;
  flex-wrap: wrap;
}

.field {
  flex: 1;
  min-width: 160rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #57534E;
  margin-bottom: 12rpx;
}

.picker {
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.input {
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 120rpx;
}

.char-count {
  display: block;
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #A8A29E;
}

.field-hint-pain {
  margin-top: 4rpx;
  margin-bottom: 10rpx;
}

.textarea-pain-detail {
  min-height: 72rpx;
  max-height: 140rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.flex-1 {
  flex: 1;
}

.teach-link-block {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f4;
}

.teach-link-block:last-of-type {
  border-bottom: none;
}

.teach-link-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.teach-link-title-input {
  margin-bottom: 0;
}

.teach-link-remove {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #78716c;
  padding: 8rpx 12rpx;
}

.link-add-teach {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #292524;
  font-weight: 500;
}

.btn-add {
  padding: 20rpx 28rpx;
  background: #FAFAF9;
  color: #1C1917;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.injury-list {
  margin-bottom: 20rpx;
}

.injury-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #FAFAF9;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.remove {
  color: #57534E;
  font-size: 24rpx;
}

.link {
  color: #292524;
  font-weight: 500;
}

.empty-tip {
  font-size: 24rpx;
  color: #A8A29E;
  text-align: center;
  padding: 28rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.step-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #FAFAF9;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
}

.step-info {
  flex: 1;
}

.step-order {
  font-weight: 500;
  color: #57534E;
  margin-right: 8rpx;
}

.step-text {
  color: #1C1917;
}

.step-actions {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
}

.step-form {
  padding-top: 20rpx;
  border-top: 1rpx solid #E7E5E4;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.add-step-btn {
  margin-top: 12rpx;
}

.decision-list {
  margin-bottom: 20rpx;
}

.decision-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #FAFAF9;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.decision-text {
  flex: 1;
}

.decision-form {
  margin-top: 20rpx;
}

.decision-form .row {
  margin-bottom: 12rpx;
}

.btn-sm {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
}

.note-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.note-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.note-input {
  flex: 1;
}

.tech-name {
  font-weight: 500;
}

.tech-tags {
  font-size: 24rpx;
  color: #57534E;
  display: block;
  margin-top: 12rpx;
}

.tech-actions {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
}

.danger {
  color: #57534E;
}

.submit {
  margin-top: 56rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 16rpx 16rpx 0 0;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #E7E5E4;
}

.modal-title {
  font-weight: 600;
}

.modal-body {
  padding: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.btn-outline {
  flex: 1;
  padding: 20rpx;
  border: 1rpx solid #E7E5E4;
  border-radius: 12rpx;
  text-align: center;
  color: #1C1917;
}

.modal-actions .btn-primary {
  flex: 1;
}

.btn-tag-add {
  font-weight: 600;
  color: #292524;
}

.tag-dialog-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.tag-dialog-box {
  width: 100%;
  max-width: 600rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 36rpx 28rpx;
  border: 1rpx solid #E7E5E4;
}

.tag-dialog-title {
  display: block;
  font-weight: 600;
  font-size: 30rpx;
  margin-bottom: 24rpx;
  color: #1C1917;
}

.tag-dialog-input {
  margin-bottom: 28rpx;
}

.tag-dialog-actions {
  display: flex;
  gap: 20rpx;
}

.tag-dialog-ok {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 保存成功：灰色方框 + 较大字号（替代 showToast） */
.record-save-tip-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.record-save-tip-box {
  background: #9CA3AF;
  border-radius: 20rpx;
  padding: 44rpx 48rpx;
  max-width: 86%;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.18);
}

.record-save-tip-text {
  font-size: 36rpx;
  line-height: 1.55;
  color: #F9FAFB;
  font-weight: 500;
  text-align: center;
}

.field-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.expand-btn {
  font-size: 24rpx;
  color: #78716C;
}

.expand-hint-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.expand-hint {
  font-size: 22rpx;
  color: #A8A29E;
}

.expand-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  z-index: 999;
  display: flex;
  flex-direction: column;
}

.expand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E7E5E4;
}

.expand-close {
  font-size: 36rpx;
  color: #78716C;
  width: 60rpx;
}

.expand-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1917;
  flex: 1;
  text-align: center;
}

.expand-done {
  font-size: 28rpx;
  color: #292524;
  font-weight: 500;
  width: 60rpx;
  text-align: right;
}

.expand-textarea {
  width: 100%;
  height: calc(100vh - 120rpx);
  padding: 32rpx;
  font-size: 32rpx;
  color: #1C1917;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
  background: transparent;
  border: none;
  box-sizing: border-box;
}
